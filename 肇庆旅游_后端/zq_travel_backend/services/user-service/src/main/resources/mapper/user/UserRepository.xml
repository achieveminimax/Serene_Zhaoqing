<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zqtravel.user.repository.UserRepository">

    <resultMap id="BaseResultMap" type="com.zqtravel.user.entity.User">
        <id column="id" property="id" />
        <result column="openid" property="openid" />
        <result column="phone" property="phone" />
        <result column="nickname" property="nickname" />
        <result column="avatar_url" property="avatarUrl" />
        <result column="gender" property="gender" />
        <result column="status" property="status" />
        <result column="last_login_at" property="lastLoginAt" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
        <result column="is_deleted" property="isDeleted" />
    </resultMap>

    <sql id="Base_Column_List">
        id, openid, phone, nickname, avatar_url, gender, status, 
        last_login_at, created_at, updated_at, is_deleted
    </sql>

    <select id="selectByPhone" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List" />
        FROM users
        WHERE phone = #{phone}
        AND is_deleted = 0
        LIMIT 1
    </select>

    <select id="selectByOpenid" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List" />
        FROM users
        WHERE openid = #{openid}
        AND is_deleted = 0
        LIMIT 1
    </select>

</mapper>