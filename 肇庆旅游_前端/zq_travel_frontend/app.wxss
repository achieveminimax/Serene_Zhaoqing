page {
  background: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", "Helvetica Neue", Helvetica, Arial, sans-serif;
  height: 100%;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  color: #333;
  animation: pageFadeIn 0.3s ease;
}

/* 页面进入动画 */
@keyframes pageFadeIn {
  from { 
    opacity: 0; 
    transform: translateY(20rpx); 
  }
  to { 
    opacity: 1; 
    transform: translateY(0); 
  }
}

view {
  box-sizing: border-box;
}

/* 统一按钮按压效果 */
.btn, 
.btn-primary,
.btn-secondary,
button {
  transition: all 0.2s ease;
}

.btn:active, 
.btn-primary:active,
.btn-secondary:active,
button:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 统一卡片按压效果 */
.card,
.artistic-card,
.scenic-card,
.music-item,
.recipe-item,
.widget-item,
.song-item,
.nature-item,
.meditation-item {
  transition: all 0.3s ease;
}

.card:active,
.artistic-card:active,
.scenic-card:active,
.music-item:active,
.recipe-item:active,
.widget-item:active,
.song-item:active,
.nature-item:active,
.meditation-item:active {
  transform: scale(0.98);
}

/* 统一圆角变量 */
:root {
  --radius-sm: 12rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
}

/* 深色模式适配 */
@media (prefers-color-scheme: dark) {
  page {
    background: #1a1a1a;
    color: #e0e0e0;
  }
}
