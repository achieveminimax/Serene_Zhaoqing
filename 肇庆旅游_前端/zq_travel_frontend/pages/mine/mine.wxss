/* 我的页面样式 - 参考 mobile_3 风格 */
.mine-container {
  min-height: 100vh;
  background: #f6faf8;
}

/* 顶部安全区域 - 适配手机刘海和状态栏 */
.safe-area-top {
  height: constant(safe-area-inset-top);
  height: env(safe-area-inset-top);
  min-height: 40rpx;
  background: rgba(236, 253, 245, 0.7);
}

/* 顶部 Header */
.mine-header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(236, 253, 245, 0.7);
  backdrop-filter: blur(20rpx);
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-icon {
  font-size: 36rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #065f46;
  letter-spacing: -0.5rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.header-notify,
.header-settings {
  font-size: 32rpx;
  opacity: 0.6;
}

/* 内容区域 */
.content-scroll {
  padding-bottom: 40rpx;
}

/* 用户身份区域 */
.user-identity-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  gap: 24rpx;
}

.avatar-wrapper {
  position: relative;
  width: 224rpx;
  height: 224rpx;
}

.user-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 8rpx solid #fff;
  box-shadow: 0 8rpx 32rpx rgba(6, 95, 70, 0.1);
}

.verified-badge {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: #059669;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
}

.verified-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.user-name-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.user-display-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #1f2937;
  letter-spacing: -1rpx;
}

.user-level-tag {
  padding: 12rpx 24rpx;
  background: #cfe5ff;
  border-radius: 32rpx;
}

.level-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #24557d;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

/* Bento 网格小组件 */
.bento-widgets {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.bento-card {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 1rpx 1rpx rgba(255, 255, 255, 0.4);
}

.bento-large {
  grid-column: span 2;
  height: 320rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.bento-small {
  height: 240rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.bento-content {
  z-index: 1;
}

.bento-icon-large {
  font-size: 48rpx;
  display: block;
  margin-bottom: 16rpx;
}

.bento-label {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 600;
  display: block;
}

.bento-value {
  font-size: 64rpx;
  font-weight: 800;
  color: #059669;
  display: block;
  margin-top: 8rpx;
}

.bento-bg-icon {
  position: absolute;
  right: -40rpx;
  bottom: -40rpx;
  font-size: 200rpx;
  opacity: 0.1;
}

.bento-goal {
  z-index: 1;
  align-self: flex-start;
  padding: 12rpx 24rpx;
  background: rgba(5, 150, 105, 0.1);
  border-radius: 32rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #059669;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.bento-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.bento-icon-small {
  font-size: 40rpx;
}

.bento-live {
  font-size: 20rpx;
  font-weight: 700;
  color: #9ca3af;
  text-transform: uppercase;
}

.bento-body {
  margin-top: auto;
}

.bento-value-small {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.bento-unit {
  font-size: 24rpx;
  font-weight: 500;
  color: #6b7280;
}

.bento-desc {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.bento-title-small {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

/* 区块样式 */
.section {
  margin-top: 48rpx;
  padding: 0 32rpx;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.section-more {
  font-size: 24rpx;
  font-weight: 600;
  color: #059669;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

/* 玻璃卡片 */
.glass-card {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* 时间轴 */
.timeline-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.timeline-item {
  display: flex;
  gap: 24rpx;
  position: relative;
}

.timeline-line {
  position: absolute;
  left: 38rpx;
  top: 80rpx;
  width: 4rpx;
  height: calc(100% + 24rpx);
  background: #e1eae7;
}

.timeline-dot {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 1;
}

.timeline-dot-primary {
  background: #a0f3da;
}

.timeline-dot-secondary {
  background: #cfe5ff;
}

.timeline-icon {
  font-size: 40rpx;
}

.timeline-card {
  flex: 1;
  padding: 24rpx;
  border-radius: 20rpx;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.timeline-time {
  font-size: 20rpx;
  color: #9ca3af;
}

.timeline-desc {
  font-size: 24rpx;
  color: #6b7280;
}

/* 疗愈食谱滚动 */
.recipe-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.recipe-card {
  display: inline-block;
  width: 480rpx;
  margin-right: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: inset 0 1rpx 1rpx rgba(255, 255, 255, 0.4);
}

.recipe-card-image {
  width: 100%;
  height: 256rpx;
}

.recipe-card-content {
  padding: 24rpx;
}

.recipe-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.recipe-card-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.3;
  white-space: normal;
  flex: 1;
}

.recipe-card-icon {
  font-size: 32rpx;
  color: #059669;
}

.recipe-card-tags {
  display: flex;
  gap: 12rpx;
}

.recipe-tag {
  padding: 8rpx 16rpx;
  background: #e1eae7;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #57615f;
}

/* 设置列表 */
.settings-section {
  margin-top: 48rpx;
  padding: 0 32rpx;
  background: #eff5f3;
  border-radius: 24rpx;
  margin-left: 32rpx;
  margin-right: 32rpx;
  padding: 16rpx;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.settings-item:last-child {
  margin-bottom: 0;
}

.settings-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.settings-icon {
  font-size: 36rpx;
}

.settings-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.settings-arrow {
  font-size: 36rpx;
  color: #9ca3af;
  font-weight: 300;
}

/* 底部留白 */
.bottom-spacer {
  height: 200rpx;
}
