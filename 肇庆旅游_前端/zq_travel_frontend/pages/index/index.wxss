/* 首页样式 - 参考 mobile_1 风格 */
.container {
  min-height: 100vh;
  background: #f6faf8;
}

/* 顶部安全区域 - 适配手机刘海和状态栏 */
.safe-area-top {
  height: constant(safe-area-inset-top);
  height: env(safe-area-inset-top);
  min-height: 40rpx;
  background: rgba(236, 253, 245, 0.7);
}

/* 顶部 Header - 改为不固定 */
.top-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(236, 253, 245, 0.7);
  backdrop-filter: blur(20rpx);
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-icon {
  font-size: 36rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #065f46;
  letter-spacing: -0.5rpx;
}

.header-right {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e1eae7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-notify {
  font-size: 32rpx;
}

/* 内容区域 */
.content-scroll {
  padding-bottom: 40rpx;
}

/* 搜索框 */
.search-section {
  padding: 32rpx;
  padding-bottom: 16rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #eff5f3;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  gap: 16rpx;
}

.search-icon {
  font-size: 32rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
}

.search-input::placeholder {
  color: #9ca3af;
}

/* 轮播图区域 - 高性能优化版 */
.carousel-section {
  margin-top: 16rpx;
}

/* Swiper 样式 - 精简高性能 */
.carousel-swiper {
  height: 680rpx;
}

.swiper-item {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.carousel-item {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  transform: scale(0.9);
  opacity: 0.6;
  transition: transform 0.35s ease-out, opacity 0.35s ease-out;
  will-change: transform, opacity;
  margin: 0 auto;
}

.carousel-item.active {
  transform: scale(1);
  opacity: 1;
}

/* 图片 - 移除复杂动画 */
.carousel-image {
  width: 100%;
  height: 100%;
}

/* 多层渐变遮罩 */
.carousel-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(6, 95, 70, 0.85) 0%,
    rgba(6, 95, 70, 0.4) 30%,
    rgba(6, 95, 70, 0.1) 60%,
    transparent 100%
  );
  opacity: 0.9;
  transition: opacity 0.5s ease;
}

.carousel-item.active .carousel-overlay {
  opacity: 1;
  animation: overlayBreathe 4s ease-in-out infinite alternate;
}

@keyframes overlayBreathe {
  0% {
    opacity: 0.95;
  }
  100% {
    opacity: 1;
  }
}

/* 闪光效果 */
.carousel-shine {
  position: absolute;
  top: -100%;
  left: -100%;
  width: 300%;
  height: 300%;
  background: linear-gradient(
    45deg,
    transparent 42%,
    rgba(255, 255, 255, 0.03) 48%,
    rgba(255, 255, 255, 0.08) 50%,
    rgba(255, 255, 255, 0.03) 52%,
    transparent 58%
  );
  animation: shineSweep 5s ease-in-out infinite;
  pointer-events: none;
}

@keyframes shineSweep {
  0% {
    transform: translateX(-30%) rotate(35deg);
    opacity: 0;
  }
  20% {
    opacity: 1;
  }
  80% {
    opacity: 1;
  }
  100% {
    transform: translateX(30%) rotate(35deg);
    opacity: 0;
  }
}

/* 内容区域 */
.carousel-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx;
  z-index: 10;
}

/* 标签动画 */
.carousel-tag-wrapper {
  overflow: hidden;
  margin-bottom: 16rpx;
}

.carousel-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #a0f3da 0%, #92e4cc 100%);
  color: #065f46;
  border-radius: 32rpx;
  font-size: 20rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(160, 243, 218, 0.3);
  transform: translateX(-20rpx);
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1) 0.2s;
}

.carousel-item.active .carousel-tag {
  transform: translateX(0);
  opacity: 1;
}

/* 标题动画 */
.carousel-title-wrapper {
  overflow: hidden;
  margin-bottom: 8rpx;
}

.carousel-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  text-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.2);
  transform: translateY(40rpx);
  opacity: 0;
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1) 0.25s;
}

.carousel-item.active .carousel-title {
  transform: translateY(0);
  opacity: 1;
}

/* 描述文字动画 */
.carousel-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 0.05em;
  transform: translateY(20rpx);
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1) 0.4s;
}

.carousel-item.active .carousel-desc {
  transform: translateY(0);
  opacity: 1;
}

/* 分页指示器 - 精简 */
.carousel-dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  margin-top: 32rpx;
}

.dot-wrapper {
  padding: 8rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #c5d5d0;
  transition: all 0.3s ease;
}

.dot-active {
  width: 28rpx;
  background: linear-gradient(90deg, #059669 0%, #10b981 100%);
  animation: dotGlow 2s ease-in-out infinite;
}

@keyframes dotGlow {
  0%, 100% {
    box-shadow: 0 2rpx 8rpx rgba(5, 150, 105, 0.3);
  }
  50% {
    box-shadow: 0 2rpx 16rpx rgba(5, 150, 105, 0.5);
  }
}

/* 进度条 - 简化 */
.carousel-progress {
  padding: 0 100rpx;
  margin-top: 20rpx;
}

.progress-track {
  height: 3rpx;
  background: rgba(197, 213, 208, 0.5);
  border-radius: 2rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #059669;
  border-radius: 2rpx;
  transition: width 0.3s ease;
}

/* 区块样式 */
.section {
  margin-top: 64rpx;
  padding: 0 32rpx;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 32rpx;
}

.section-header-col {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  letter-spacing: -0.5rpx;
}

.section-subtitle {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.section-more {
  font-size: 26rpx;
  font-weight: 600;
  color: #059669;
}

/* 玻璃卡片效果 */
.glass-card {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* 精选旅程 */
.journey-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.journey-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  align-items: center;
}

.journey-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.journey-info {
  flex: 1;
  min-width: 0;
}

.journey-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.journey-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.journey-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #e1eae7;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #059669;
  border-radius: 4rpx;
}

.progress-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #059669;
}

.journey-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 20rpx;
}

.action-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #059669;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.action-icon {
  font-size: 24rpx;
  color: #059669;
}

/* 热门景点推荐 */
.featured-spot-card {
  position: relative;
  width: 100%;
  aspect-ratio: 16/10;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.featured-spot-image {
  width: 100%;
  height: 100%;
}

.featured-spot-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.1) 50%, transparent 100%);
}

.featured-spot-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
}

.featured-spot-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  color: #fff;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.featured-spot-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.featured-spot-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

/* 景点网格 */
.spots-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.spot-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.spot-emoji {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eff5f3;
  border-radius: 20rpx;
}

.spot-info {
  flex: 1;
  min-width: 0;
}

.spot-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.spot-subtitle {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
  display: block;
}

.spot-arrow {
  font-size: 40rpx;
  color: #9ca3af;
  font-weight: 300;
}

/* 风景推荐 */
.landscape-card {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.landscape-image {
  width: 100%;
  height: 100%;
}

.landscape-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.2);
}

.landscape-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 32rpx;
}

.badge-icon {
  font-size: 24rpx;
}

.badge-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.landscape-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
}

.landscape-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.landscape-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

/* 风景网格 */
.landscape-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 24rpx;
}

.landscape-item {
  background: #eff5f3;
  border-radius: 20rpx;
  padding: 24rpx;
}

.item-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 16rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.item-desc {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

/* 更多景点展示 */
.more-spots-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.more-spot-item {
  display: flex;
  gap: 24rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.more-spot-image {
  width: 200rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.more-spot-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.more-spot-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.more-spot-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.more-spot-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.spot-tag {
  padding: 8rpx 16rpx;
  background: #eff5f3;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #059669;
}

/* 底部留白 - 增加高度避免与导航栏重叠 */
.bottom-spacer {
  height: 200rpx;
}

/* 悬浮按钮 - 移到更高位置避免与导航栏重叠 */
.fab-button {
  position: fixed;
  bottom: 180rpx;
  right: 32rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #059669 0%, #34d399 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(5, 150, 105, 0.3);
  z-index: 50;
}

.fab-icon {
  font-size: 48rpx;
}
