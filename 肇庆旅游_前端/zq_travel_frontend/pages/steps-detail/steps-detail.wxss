.steps-detail-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f6faf8;
  overflow: hidden;
}

/* 玻璃面板通用样式 */
.glass-panel {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

/* 顶部导航栏 */
.top-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-top: env(safe-area-inset-top);
  background: rgba(246, 250, 248, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
}

.back-btn, .more-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
}

.back-btn:active, .more-btn:active {
  transform: scale(0.95);
  background: rgba(0, 0, 0, 0.05);
}

.nav-icon {
  font-size: 40rpx;
  color: #076c59;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #076c59;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

/* 主内容区 */
.main-content {
  flex: 1;
  padding-top: calc(100rpx + env(safe-area-inset-top));
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  padding-left: 32rpx;
  padding-right: 32rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  box-sizing: border-box;
}

/* 环形进度区 */
.progress-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 32rpx;
  margin-bottom: 40rpx;
  width: 100%;
}

.progress-circle-wrapper {
  position: relative;
  width: 520rpx;
  height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 50%;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.08);
}

/* 外圈辉光效果 */
.progress-glow {
  position: absolute;
  top: -20rpx;
  left: -20rpx;
  right: -20rpx;
  bottom: -20rpx;
  border-radius: 50%;
  background: conic-gradient(from 0deg, #076c59, #0d9488, #a0f3da, #076c59);
  opacity: 0.3;
  filter: blur(30rpx);
  animation: glow-rotate 8s linear infinite;
  z-index: -1;
}

@keyframes glow-rotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.progress-svg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.track-circle {
  stroke: #e1eae7;
}

.progress-circle {
  transition: stroke-dashoffset 0.8s ease-out;
}

.circle-content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.steps-value {
  font-size: 72rpx;
  font-weight: 800;
  color: #2a3433;
  font-family: 'Plus Jakarta Sans', sans-serif;
  letter-spacing: -2rpx;
}

.steps-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #57615f;
  letter-spacing: 2rpx;
}

.progress-tip {
  margin-top: 32rpx;
  padding: 20rpx 40rpx;
  border-radius: 48rpx;
}

.tip-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #005d4c;
}

/* 数据统计网格 (Bento Style) */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  gap: 16rpx;
}

.stat-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(7, 108, 89, 0.08);
}

.stat-icon {
  font-size: 36rpx;
}

.stat-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #2a3433;
}

.stat-label {
  font-size: 18rpx;
  font-weight: 600;
  color: #727d7b;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* 步数趋势 */
.trends-section {
  margin-bottom: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2a3433;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

.section-desc {
  font-size: 22rpx;
  font-weight: 500;
  color: #727d7b;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.chart-card {
  padding: 32rpx;
  height: 320rpx;
  position: relative;
  overflow: hidden;
}

.chart-wrapper {
  position: relative;
  height: 200rpx;
  width: 100%;
}

.trend-svg {
  width: 100%;
  height: 100%;
}

.area-path {
  fill: url(#areaGradient);
}

.line-path {
  stroke: #076c59;
  stroke-width: 3;
  stroke-linecap: round;
  fill: none;
}

.active-point {
  filter: drop-shadow(0 0 4rpx rgba(7, 108, 89, 0.4));
}

.week-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
}

.week-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #727d7b;
  letter-spacing: 1rpx;
}

/* 疗愈路线推荐 */
.routes-section {
  margin-bottom: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.routes-section .section-title {
  margin-bottom: 20rpx;
}

.routes-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.route-card {
  position: relative;
  height: 160rpx;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  overflow: hidden;
  transition: transform 0.2s;
}

.route-card:active {
  transform: scale(0.98);
}

.route-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.15;
}

.route-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.6) 100%);
}

.route-content {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.route-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #2a3433;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

.route-info {
  display: flex;
  gap: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-icon {
  font-size: 24rpx;
}

.info-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #57615f;
}

.route-arrow-btn {
  position: relative;
  z-index: 10;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(7, 108, 89, 0.1);
  margin-left: 16rpx;
}

.arrow-icon {
  font-size: 36rpx;
  color: #076c59;
  font-weight: bold;
}

/* 健康概览 */
.health-section {
  margin-bottom: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.health-section .section-title {
  margin-bottom: 20rpx;
}

.health-scroll {
  width: 100%;
}

.health-cards {
  display: flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
  padding-left: 0;
}

.health-card {
  flex-shrink: 0;
  width: 280rpx;
  display: flex;
  flex-direction: column;
  padding: 28rpx;
  gap: 20rpx;
  border: 1rpx solid rgba(7, 108, 89, 0.1);
}

.health-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(7, 108, 89, 0.08);
}

.health-icon {
  font-size: 36rpx;
}

.health-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.health-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.health-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #2a3433;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

.health-unit {
  font-size: 22rpx;
  font-weight: 500;
  color: #57615f;
}

.health-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #727d7b;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* 底部留白 */
.bottom-spacer {
  height: 48rpx;
}
