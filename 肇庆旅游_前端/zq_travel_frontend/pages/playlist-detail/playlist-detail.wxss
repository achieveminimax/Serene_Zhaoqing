page {
  background-color: #f6faf8;
}

/* 主容器 */
.playlist-container {
  min-height: 100vh;
  background-color: #f6faf8;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部导航栏 - 透明融合风格 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: calc(20rpx + env(safe-area-inset-top)) 32rpx 20rpx;
  background: transparent;
}

.nav-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.nav-btn:active {
  background: rgba(255, 255, 255, 0.5);
  transform: scale(0.95);
}

.iconfont {
  font-size: 36rpx;
  color: #2a3433;
  line-height: 1;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2a3433;
  text-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.5);
}

/* 沉浸式头部区域 */
.header-section {
  position: relative;
  width: 100%;
  height: 920rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  overflow: hidden;
  padding-top: calc(160rpx + env(safe-area-inset-top));
}

/* 背景模糊图 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
}

.bg-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: blur(60rpx);
  transform: scale(1.25);
  opacity: 0.6;
}

.bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, transparent 0%, rgba(246, 250, 248, 0.2) 50%, #f6faf8 100%);
}

/* 头部内容 */
.header-content {
  position: relative;
  z-index: 10;
  width: 100%;
  padding: 0 64rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

/* 封面图 */
.cover-wrapper {
  width: 380rpx;
  height: 380rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.cover-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 歌单标题 */
.playlist-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #2a3433;
  letter-spacing: -1rpx;
  margin-bottom: 16rpx;
  line-height: 1.2;
}

/* 歌单描述 */
.playlist-desc {
  font-size: 28rpx;
  color: rgba(42, 52, 51, 0.6);
  max-width: 600rpx;
  line-height: 1.5;
  margin-bottom: 64rpx;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 32rpx;
  width: 100%;
  max-width: 600rpx;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(to bottom right, #076c59, #a0f3da);
  color: #e4fff4;
  font-weight: 700;
  padding: 32rpx 0;
  border-radius: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(7, 108, 89, 0.2);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.95);
}

.btn-secondary {
  flex: 1;
  background: #e1eae7;
  color: #076c59;
  font-weight: 700;
  padding: 32rpx 0;
  border-radius: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  transform: scale(0.95);
  background: #d1dcd9;
}

.btn-icon {
  font-size: 32rpx;
  color: inherit;
}

.btn-text {
  font-size: 30rpx;
}

/* 歌曲列表 */
.track-list {
  padding: 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.track-item {
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  transition: all 0.3s ease;
}

.track-item:active {
  background: rgba(255, 255, 255, 0.6);
}

.track-item.playing {
  background: rgba(160, 243, 218, 0.2);
}

.track-number {
  width: 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(42, 52, 51, 0.3);
  text-align: center;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

.track-item.playing .track-number {
  color: #076c59;
}

.track-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.track-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2a3433;
  transition: color 0.3s ease;
}

.track-item.playing .track-name {
  color: #076c59;
}

.text-primary {
  color: #076c59;
}

.track-artist {
  font-size: 24rpx;
  color: rgba(42, 52, 51, 0.5);
}

.track-duration {
  font-size: 24rpx;
  color: rgba(42, 52, 51, 0.4);
  font-family: monospace;
}

.track-more {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.track-more:active {
  background: rgba(7, 108, 89, 0.1);
}

.more-icon {
  font-size: 40rpx;
  color: rgba(42, 52, 51, 0.4);
}

/* 底部安全区域 */
.safe-area-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
  min-height: 32rpx;
}

/* 滚动条隐藏 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}
