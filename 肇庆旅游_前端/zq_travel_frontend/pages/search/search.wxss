.search-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f6faf8;
  overflow: hidden;
}

/* 顶部导航栏 */
.top-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-top: env(safe-area-inset-top);
  background: rgba(232, 250, 237, 0.7);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.05);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: opacity 0.2s;
}

.back-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.icon-arrow-left {
  font-size: 40rpx;
  color: #076c59;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #076c59;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

.filter-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: opacity 0.2s;
}

.filter-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.icon-filter {
  font-size: 40rpx;
  color: #076c59;
}

/* 主内容区 */
.main-content {
  flex: 1;
  padding-top: calc(120rpx + env(safe-area-inset-top));
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
  padding-left: 32rpx;
  padding-right: 32rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 搜索框 */
.search-bar-section {
  margin-bottom: 48rpx;
}

.search-bar {
  position: relative;
  display: flex;
  align-items: center;
  background: #e8f0ed;
  border-radius: 56rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.search-bar:focus-within {
  background: #dae5e2;
  box-shadow: 0 4rpx 20rpx rgba(7, 108, 89, 0.15);
}

.search-icon {
  position: absolute;
  left: 32rpx;
  display: flex;
  align-items: center;
}

.icon-search {
  font-size: 40rpx;
  color: #076c59;
}

.search-input {
  flex: 1;
  font-size: 32rpx;
  color: #2a3433;
  padding-left: 48rpx;
  padding-right: 64rpx;
}

.search-input::placeholder {
  color: #727d7b;
}

.clear-btn {
  position: absolute;
  right: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.clear-btn:active {
  background: rgba(0, 0, 0, 0.05);
}

.icon-close {
  font-size: 32rpx;
  color: #727d7b;
}

/* 区域标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2a3433;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

.clear-all-btn {
  font-size: 24rpx;
  font-weight: 500;
  color: #727d7b;
  transition: color 0.2s;
}

.clear-all-btn:active {
  color: #a83836;
}

/* 最近搜索 - 玻璃卡片 */
.history-section {
  margin-bottom: 48rpx;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-chip {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  transition: background 0.2s;
}

.history-chip:active {
  background: rgba(225, 234, 231, 0.8);
}

.chip-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #2a3433;
  margin-right: 8rpx;
}

.chip-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  opacity: 0;
  transition: opacity 0.2s;
}

.history-chip:active .chip-close {
  opacity: 1;
}

.icon-close-small {
  font-size: 20rpx;
  color: #727d7b;
}

/* 热门搜索 */
.trending-section {
  margin-bottom: 48rpx;
}

.trending-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.trending-chip {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border-radius: 48rpx;
  transition: all 0.2s;
}

.trending-chip:active {
  opacity: 0.8;
}

.bg-secondary {
  background: rgba(207, 229, 255, 0.3);
}

.bg-secondary:active {
  background: rgba(207, 229, 255, 0.5);
}

.bg-primary {
  background: rgba(160, 243, 218, 0.3);
}

.bg-primary:active {
  background: rgba(160, 243, 218, 0.5);
}

.bg-tertiary {
  background: rgba(253, 226, 223, 0.3);
}

.bg-tertiary:active {
  background: rgba(253, 226, 223, 0.5);
}

.bg-surface {
  background: #e1eae7;
}

.bg-surface:active {
  background: #dae5e2;
}

.trending-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.text-on-secondary {
  color: #305f88;
}

.text-on-primary {
  color: #005d4c;
}

.text-on-tertiary {
  color: #64514f;
}

.text-on-surface {
  color: #57615f;
}

/* 猜你喜欢 */
.suggested-section {
  margin-bottom: 32rpx;
}

.suggested-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.suggested-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  transition: transform 0.3s;
}

.suggested-card:active {
  transform: scale(0.98);
}

/* 大卡片 */
.featured-card {
  height: 320rpx;
}

.featured-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s;
}

.featured-card:active .featured-image {
  transform: scale(1.05);
}

.featured-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80%;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
}

.featured-content {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.featured-tag {
  background: rgba(160, 243, 218, 0.9);
  color: #005d4c;
  font-size: 16rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  text-transform: uppercase;
  align-self: flex-start;
  letter-spacing: 1rpx;
}

.featured-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  font-family: 'Plus Jakarta Sans', sans-serif;
  line-height: 1.2;
}

.featured-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

/* 小卡片网格 */
.small-cards-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

/* 小卡片 */
.small-card {
  padding: 32rpx;
  min-height: 240rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.surface-low {
  background: #eff5f3;
  transition: background 0.2s;
}

.small-card:active {
  background: #ffffff;
}

.small-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.small-card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-secondary {
  background: rgba(207, 229, 255, 0.3);
  color: #076c59;
}

.icon-tertiary {
  background: rgba(253, 226, 223, 0.3);
  color: #6e5a58;
}

.icon-emoji {
  font-size: 40rpx;
}

.small-card-more {
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-more {
  font-size: 40rpx;
  color: #727d7b;
}

.small-card-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.small-card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #2a3433;
}

.small-card-desc {
  font-size: 20rpx;
  color: #57615f;
  line-height: 1.4;
}
