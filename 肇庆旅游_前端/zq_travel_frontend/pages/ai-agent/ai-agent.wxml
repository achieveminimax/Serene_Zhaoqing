<view class="ai-container">
  <!-- 顶部导航栏 -->
  <view class="ai-header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="header-center">
      <view class="agent-info">
        <text class="agent-avatar">🌿</text>
        <view class="agent-text">
          <text class="agent-name">疗愈助手</text>
          <text class="agent-status">在线</text>
        </view>
      </view>
    </view>
    <view class="header-right" bindtap="clearChat">
      <text class="clear-icon">✦</text>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view 
    class="message-list" 
    scroll-y 
    scroll-into-view="{{scrollToMessage}}"
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 欢迎消息 -->
    <view class="welcome-card" wx:if="{{messages.length === 0}}">
      <view class="welcome-icon">✨</view>
      <text class="welcome-title">开启您的疗愈对话</text>
      <text class="welcome-desc">我是您的专属疗愈助手，可以为您解答肇庆旅游、冥想练习、身心健康等方面的问题</text>
    </view>

    <!-- 消息项 -->
    <view 
      class="message-wrapper {{msg.role}}" 
      wx:for="{{messages}}" 
      wx:for-item="msg" 
      wx:key="id" 
      id="msg-{{index}}"
    >
      <!-- 时间分隔线 -->
      <view class="time-divider" wx:if="{{msg.showTime}}">
        <text class="time-text">{{msg.timeText}}</text>
      </view>

      <!-- AI消息 -->
      <view class="message-bubble ai" wx:if="{{msg.role === 'assistant'}}">
        <view class="bubble-content">
          <view class="bubble-text markdown-wrapper">
            <markdown-render content="{{msg.content}}"></markdown-render>
          </view>
          <view class="bubble-actions">
            <text class="action-btn" bindtap="copyMessage" data-content="{{msg.content}}">复制</text>
            <text class="action-btn" bindtap="likeMessage" data-id="{{msg.id}}">♥</text>
          </view>
        </view>
      </view>

      <!-- 用户消息 -->
      <view class="message-bubble user" wx:if="{{msg.role === 'user'}}">
        <view class="bubble-content">
          <view class="bubble-text">{{msg.content}}</view>
        </view>
      </view>
    </view>

    <!-- 加载中 - 增强动画效果 -->
    <view class="loading-wrapper" wx:if="{{loading}}">
      <view class="loading-bubble">
        <view class="loading-content">
          <view class="loading-waves">
            <view class="wave"></view>
            <view class="wave"></view>
            <view class="wave"></view>
          </view>
          <text class="loading-text">思考中</text>
        </view>
        <view class="loading-shimmer"></view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-space" id="bottom-space"></view>
  </scroll-view>

  <!-- 快捷问题 -->
  <view class="quick-questions" wx:if="{{messages.length < 3}}">
    <scroll-view class="quick-scroll" scroll-x show-scrollbar="{{false}}">
      <view class="quick-list">
        <view class="quick-item" bindtap="quickAsk" data-question="鼎湖山有什么好玩的？">
          <text class="quick-icon">🏔️</text>
          <text class="quick-text">鼎湖山攻略</text>
        </view>
        <view class="quick-item" bindtap="quickAsk" data-question="推荐一个5分钟冥想">
          <text class="quick-icon">🧘</text>
          <text class="quick-text">快速冥想</text>
        </view>
        <view class="quick-item" bindtap="quickAsk" data-question="肇庆有哪些特色美食？">
          <text class="quick-icon">🍜</text>
          <text class="quick-text">美食推荐</text>
        </view>
        <view class="quick-item" bindtap="quickAsk" data-question="最近压力很大，怎么办？">
          <text class="quick-icon">💆</text>
          <text class="quick-text">减压建议</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 输入区域 -->
  <view class="input-area">
    <view class="input-wrapper">
      <input 
        class="message-input" 
        placeholder="输入您的问题..."
        placeholder-class="input-placeholder"
        value="{{inputValue}}"
        bindinput="onInputChange"
        confirm-type="send"
        bindconfirm="sendMessage"
        adjust-position
        cursor-spacing="20"
      />
      <view class="send-btn {{inputValue ? 'active' : ''}}" bindtap="sendMessage">
        <text class="send-icon">↑</text>
      </view>
    </view>
    <text class="input-hint">AI生成的内容仅供参考</text>
  </view>
</view>
