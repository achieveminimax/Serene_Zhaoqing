/* AI对话界面 - 疗愈风格 */
.ai-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6faf8;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

/* 顶部导航栏 - 玻璃态 */
.ai-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + constant(safe-area-inset-top));
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: rgba(246, 250, 248, 0.8);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-bottom: 1rpx solid rgba(143, 180, 143, 0.1);
  z-index: 100;
}

.header-left,
.header-right {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
}

.header-left:active,
.header-right:active {
  background: rgba(7, 108, 89, 0.1);
  transform: scale(0.92);
}

.back-icon {
  font-size: 40rpx;
  color: #076c59;
  font-weight: 500;
}

.clear-icon {
  font-size: 36rpx;
  color: #076c59;
}

.header-center {
  flex: 1;
  display: flex;
  justify-content: center;
}

.agent-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(7, 108, 89, 0.08);
}

.agent-avatar {
  font-size: 44rpx;
}

.agent-text {
  display: flex;
  flex-direction: column;
}

.agent-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #076c59;
}

.agent-status {
  font-size: 20rpx;
  color: #10b981;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.agent-status::before {
  content: '';
  width: 8rpx;
  height: 8rpx;
  background: #10b981;
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(0.8);
  }
}

/* 消息列表 - 唯一可滚动区域 */
.message-list {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  overscroll-behavior: contain;
}

/* 欢迎卡片 */
.welcome-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  margin-top: 40rpx;
  background: linear-gradient(135deg, rgba(160, 243, 218, 0.3) 0%, rgba(207, 229, 255, 0.3) 100%);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  text-align: center;
  animation: fadeInUp 0.6s cubic-bezier(0.23, 1, 0.32, 1);
}

@keyframes fadeInUp {
  0% {
    opacity: 0;
    transform: translateY(30rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.welcome-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #076c59;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #57615f;
  line-height: 1.6;
}

/* 消息包装器 */
.message-wrapper {
  margin-bottom: 32rpx;
  animation: messageSlideIn 0.4s cubic-bezier(0.23, 1, 0.32, 1);
}

.message-wrapper.user {
  text-align: right;
  padding-right: 10%;
  padding-left: 0;
}

.message-wrapper.ai {
  text-align: left;
  padding-left: 5%;
  padding-right: 0;
}

@keyframes messageSlideIn {
  0% {
    opacity: 0;
    transform: translateY(20rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 时间分隔线 */
.time-divider {
  display: flex;
  justify-content: center;
  margin: 32rpx 0;
}

.time-text {
  font-size: 22rpx;
  color: #9ca3af;
  background: rgba(0, 0, 0, 0.05);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

/* 消息气泡 */
.message-bubble {
  display: block;
  max-width: 90%;
  vertical-align: top;
}

.message-bubble.user {
  display: inline-flex;
  flex-direction: row-reverse;
}

/* 气泡内容 */
.bubble-content {
  flex: 1;
  min-width: 0;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(160, 243, 218, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  position: relative;
  word-wrap: break-word;
  word-break: break-all;
  overflow-wrap: break-word;
}

.message-bubble.user .bubble-content {
  background: linear-gradient(135deg, #076c59 0%, #0a8f75 100%);
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(7, 108, 89, 0.2);
}

.bubble-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #2a3433;
  word-wrap: break-word;
  word-break: break-all;
  overflow-wrap: break-word;
  display: block;
  width: 100%;
}

/* Markdown 渲染容器 */
.markdown-wrapper {
  width: 100%;
}

.message-bubble.user .bubble-text {
  color: #ffffff;
}

/* 气泡操作 */
.bubble-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(160, 243, 218, 0.2);
}

.action-btn {
  font-size: 24rpx;
  color: #076c59;
  opacity: 0.7;
  transition: opacity 0.2s;
}

.action-btn:active {
  opacity: 1;
}

/* 加载中 - 增强动画 */
.loading-wrapper {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 32rpx;
  animation: messageSlideIn 0.4s cubic-bezier(0.23, 1, 0.32, 1);
}

.loading-bubble {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 28rpx 40rpx;
  border: 1rpx solid rgba(160, 243, 218, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
  min-width: 160rpx;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

/* 波浪动画 */
.loading-waves {
  display: flex;
  gap: 8rpx;
  align-items: center;
  height: 40rpx;
}

.wave {
  width: 6rpx;
  height: 20rpx;
  background: linear-gradient(180deg, #076c59 0%, #a0f3da 100%);
  border-radius: 3rpx;
  animation: wave 1.2s ease-in-out infinite;
}

.wave:nth-child(1) {
  animation-delay: 0s;
}

.wave:nth-child(2) {
  animation-delay: 0.15s;
}

.wave:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes wave {
  0%, 100% {
    transform: scaleY(0.5);
    opacity: 0.5;
  }
  50% {
    transform: scaleY(1.2);
    opacity: 1;
  }
}

/* 思考中文字 */
.loading-text {
  font-size: 24rpx;
  color: #076c59;
  opacity: 0.7;
  animation: textFade 2s ease-in-out infinite;
}

@keyframes textFade {
  0%, 100% {
    opacity: 0.5;
  }
  50% {
    opacity: 1;
  }
}

/* 闪光扫过效果 */
.loading-shimmer {
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(160, 243, 218, 0.3) 50%,
    transparent 100%
  );
  animation: shimmer 2s ease-in-out infinite;
}

@keyframes shimmer {
  0% {
    left: -100%;
  }
  100% {
    left: 200%;
  }
}

.bottom-space {
  height: 40rpx;
}

/* 快捷问题 */
.quick-questions {
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.5);
  border-top: 1rpx solid rgba(160, 243, 218, 0.15);
}

.quick-scroll {
  white-space: nowrap;
}

.quick-list {
  display: inline-flex;
  gap: 16rpx;
}

.quick-item {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 32rpx;
  border: 1rpx solid rgba(160, 243, 218, 0.3);
  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
}

.quick-item:active {
  transform: scale(0.95);
  background: rgba(160, 243, 218, 0.3);
}

.quick-icon {
  font-size: 32rpx;
}

.quick-text {
  font-size: 26rpx;
  color: #076c59;
  font-weight: 500;
  white-space: nowrap;
}

/* 输入区域 */
.input-area {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(246, 250, 248, 0.9);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(160, 243, 218, 0.2);
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 48rpx;
  padding: 12rpx 12rpx 12rpx 32rpx;
  border: 1rpx solid rgba(160, 243, 218, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(7, 108, 89, 0.08);
}

.message-input {
  flex: 1;
  font-size: 30rpx;
  color: #2a3433;
  height: 72rpx;
}

.input-placeholder {
  color: #9ca3af;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(160, 243, 218, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
}

.send-btn.active {
  background: linear-gradient(135deg, #076c59 0%, #0a8f75 100%);
  box-shadow: 0 4rpx 16rpx rgba(7, 108, 89, 0.3);
}

.send-btn:active {
  transform: scale(0.92);
}

.send-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}

.input-hint {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 16rpx;
}

/* 滚动条隐藏 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}
