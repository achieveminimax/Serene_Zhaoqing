/* 音乐页样式 - 参考 mobile_2 风格 */
.music-container {
  min-height: 100vh;
  background: #f6faf8;
  padding-bottom: 180rpx;
}

/* 顶部安全区域 - 适配手机刘海和状态栏 */
.safe-area-top {
  height: constant(safe-area-inset-top);
  height: env(safe-area-inset-top);
  min-height: 40rpx;
  background: rgba(236, 253, 245, 0.7);
}

/* 顶部 Header - 改为不固定 */
.music-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(236, 253, 245, 0.7);
  backdrop-filter: blur(20rpx);
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-icon {
  font-size: 36rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #065f46;
  letter-spacing: -0.5rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.header-notify {
  font-size: 36rpx;
  opacity: 0.6;
}

.header-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #a0f3da;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

/* 内容区域 */
.content-scroll {
  padding-bottom: 40rpx;
}

/* Hero 搜索区域 */
.hero-section {
  padding: 32rpx;
  padding-bottom: 16rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1f2937;
  line-height: 1.2;
  margin-bottom: 32rpx;
  letter-spacing: -1rpx;
}

.highlight {
  color: #059669;
  font-style: italic;
}

.search-box {
  display: flex;
  align-items: center;
  background: #eff5f3;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  gap: 16rpx;
}

.search-icon {
  font-size: 32rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
}

.search-input::placeholder {
  color: #9ca3af;
}

/* 分类标签 */
.category-chips {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 32rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.chip {
  padding: 16rpx 32rpx;
  background: #e1eae7;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #57615f;
  transition: all 0.2s;
}

.chip-active {
  background: linear-gradient(135deg, #059669 0%, #34d399 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(5, 150, 105, 0.25);
}

/* 区块样式 */
.section {
  margin-top: 48rpx;
  padding: 0 32rpx;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.section-header-col {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.section-subtitle {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.section-more {
  font-size: 24rpx;
  font-weight: 600;
  color: #059669;
}

/* 歌单横向滚动 */
.playlist-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.playlist-card {
  display: inline-block;
  width: 320rpx;
  margin-right: 32rpx;
  vertical-align: top;
}

.playlist-cover {
  position: relative;
  width: 320rpx;
  height: 400rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.playlist-image {
  width: 100%;
  height: 100%;
}

.playlist-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%);
}

.playlist-play {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-btn-icon {
  color: #fff;
  font-size: 28rpx;
  margin-left: 4rpx;
}

.playlist-duration {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.1em;
}

.playlist-info {
  margin-top: 20rpx;
}

.playlist-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
  white-space: normal;
}

.playlist-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
  white-space: normal;
}

/* 歌曲列表 */
.song-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.song-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx;
  background: #eff5f3;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.song-item:active {
  background: #e1eae7;
}

.song-cover {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.song-info {
  flex: 1;
  min-width: 0;
}

.song-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.song-artist {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.song-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.song-duration {
  font-size: 22rpx;
  color: #9ca3af;
  font-family: monospace;
}

.song-more {
  font-size: 32rpx;
  color: #9ca3af;
  opacity: 0.5;
}

/* Bento 网格 */
.bento-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.bento-item {
  position: relative;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 240rpx;
  overflow: hidden;
}

.bento-rain {
  background: #cfe5ff;
}

.bento-breeze {
  background: #e1eae7;
}

.bento-ocean {
  grid-column: span 2;
  background: #e1eae7;
}

.bento-glow {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: #34628c;
  opacity: 0.1;
  border-radius: 50%;
  filter: blur(40rpx);
}

.bento-bg {
  position: absolute;
  right: 0;
  top: 0;
  width: 50%;
  height: 100%;
  opacity: 0.3;
  filter: grayscale(100%);
}

.bento-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, #e1eae7 0%, transparent 100%);
}

.bento-icon {
  font-size: 48rpx;
  z-index: 1;
}

.bento-text {
  z-index: 1;
}

.bento-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.bento-desc {
  font-size: 20rpx;
  font-weight: 600;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-top: 8rpx;
  display: block;
}

/* 底部留白 */
.bottom-spacer {
  height: 200rpx;
}

/* 浮动播放器 */
.floating-player {
  position: fixed;
  bottom: 140rpx;
  left: 32rpx;
  right: 32rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(6, 95, 70, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  z-index: 50;
}

.player-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.player-cover {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.player-info {
  flex: 1;
  min-width: 0;
}

.player-song {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-artist {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.player-controls {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.player-fav {
  font-size: 40rpx;
}

.player-play-btn {
  width: 80rpx;
  height: 80rpx;
  background: #059669;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
}

.player-progress {
  margin-top: 20rpx;
}

.progress-bar {
  height: 6rpx;
  background: #e1eae7;
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #059669;
  border-radius: 3rpx;
  transition: width 0.3s;
}

.progress-time {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.progress-time text {
  font-size: 20rpx;
  color: #9ca3af;
  font-family: monospace;
}
