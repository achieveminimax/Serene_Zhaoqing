/* 线性图标样式 - Iconfont */
.icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: "iconfont" !important;
  font-size: inherit;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* 图标尺寸 */
.icon-xs { font-size: 24rpx; }
.icon-sm { font-size: 32rpx; }
.icon-md { font-size: 48rpx; }
.icon-lg { font-size: 64rpx; }
.icon-xl { font-size: 96rpx; }

/* 常用图标 Unicode */
.icon-home::before { content: "\e7c6"; }
.icon-music::before { content: "\e7c5"; }
.icon-user::before { content: "\e7c4"; }
.icon-search::before { content: "\e7c3"; }
.icon-play::before { content: "\e7c2"; }
.icon-pause::before { content: "\e7c1"; }
.icon-heart::before { content: "\e7c0"; }
.icon-heart-fill::before { content: "\e7bf"; }
.icon-star::before { content: "\e7be"; }
.icon-star-fill::before { content: "\e7bd"; }
.icon-arrow-right::before { content: "\e7bc"; }
.icon-arrow-left::before { content: "\e7bb"; }
.icon-arrow-up::before { content: "\e7ba"; }
.icon-arrow-down::before { content: "\e7b9"; }
.icon-close::before { content: "\e7b8"; }
.icon-check::before { content: "\e7b7"; }
.icon-more::before { content: "\e7b6"; }
.icon-share::before { content: "\e7b5"; }
.icon-settings::before { content: "\e7b4"; }
.icon-volume::before { content: "\e7b3"; }
.icon-volume-off::before { content: "\e7b2"; }
.icon-loading::before { content: "\e7b1"; }

/* 旋转动画 */
.icon-spin {
  animation: iconSpin 1s linear infinite;
}

@keyframes iconSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 脉冲动画 */
.icon-pulse {
  animation: iconPulse 2s ease-in-out infinite;
}

@keyframes iconPulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.8; }
}

/* 心跳动画 */
.icon-heartbeat {
  animation: iconHeartbeat 1.3s ease-in-out infinite;
}

@keyframes iconHeartbeat {
  0%, 100% { transform: scale(1); }
  14% { transform: scale(1.3); }
  28% { transform: scale(1); }
  42% { transform: scale(1.3); }
  70% { transform: scale(1); }
}
