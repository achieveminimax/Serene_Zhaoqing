/* 时间轴容器 */
.timeline {
  padding: 32rpx;
  position: relative;
}

/* 时间轴项目 */
.timeline-item {
  display: flex;
  gap: 24rpx;
  position: relative;
  padding-bottom: 40rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

/* 时间节点 */
.timeline-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  flex-shrink: 0;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #e0e0e0;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.timeline-dot-active {
  background: linear-gradient(135deg, #4D6A4D 0%, #7AA87A 100%);
  box-shadow: 0 4rpx 16rpx rgba(77, 106, 77, 0.4);
  transform: scale(1.2);
}

.timeline-line {
  flex: 1;
  width: 2rpx;
  background: linear-gradient(180deg, #e0e0e0 0%, transparent 100%);
  margin-top: 8rpx;
}

/* 内容区域 */
.timeline-content {
  flex: 1;
  margin-top: -8rpx;
}

.timeline-time {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.timeline-date {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.timeline-hour {
  font-size: 22rpx;
  color: #ccc;
}

/* 内容卡片 */
.timeline-card {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.timeline-card:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.9);
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.timeline-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.timeline-status.completed {
  background: rgba(77, 106, 77, 0.1);
  color: #4D6A4D;
}

.timeline-status.pending {
  background: rgba(255, 193, 7, 0.1);
  color: #f9a825;
}

.timeline-status.cancelled {
  background: rgba(244, 67, 54, 0.1);
  color: #e53935;
}

.timeline-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.timeline-footer {
  font-size: 22rpx;
  color: #999;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* 高亮项目 */
.timeline-highlight .timeline-card {
  background: linear-gradient(135deg, rgba(77, 106, 77, 0.05) 0%, rgba(122, 168, 122, 0.05) 100%);
  border-color: rgba(77, 106, 77, 0.2);
}
