/* 沉浸式播放器 */
.immersive-player {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.player-show {
  opacity: 1;
  visibility: visible;
}

/* 背景层 */
.player-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.player-bg-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.player-bg-blur {
  position: absolute;
  top: -50%;
  left: -50%;
  right: -50%;
  bottom: -50%;
  background: inherit;
  filter: blur(60rpx);
  transform: scale(1.5);
}

.player-bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,0.7) 100%);
}

/* 内容层 */
.player-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: env(safe-area-inset-top) 32rpx calc(32rpx + env(safe-area-inset-bottom));
}

/* 顶部导航 */
.player-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.nav-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.nav-btn:active {
  background: rgba(255,255,255,0.2);
  transform: scale(0.95);
}

.nav-btn .icon {
  font-size: 36rpx;
  color: #fff;
}

.nav-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  letter-spacing: 2rpx;
}

/* 唱片区域 */
.player-disc-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.player-disc {
  width: 560rpx;
  height: 560rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 20rpx 80rpx rgba(0,0,0,0.4);
  border: 8rpx solid rgba(255,255,255,0.1);
  animation: discRotate 20s linear infinite;
  animation-play-state: paused;
}

.disc-rotate {
  animation-play-state: running;
}

@keyframes discRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.disc-image {
  width: 100%;
  height: 100%;
}

.disc-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #4D6A4D 0%, #7AA87A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.disc-placeholder .icon {
  color: #fff;
  opacity: 0.8;
}

/* 声波动画 */
.sound-waves {
  position: absolute;
  bottom: 40rpx;
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 60rpx;
}

.wave-bar {
  width: 6rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 3rpx;
  animation: wave 1s ease-in-out infinite;
}

.wave-bar:nth-child(1) { height: 20rpx; }
.wave-bar:nth-child(2) { height: 40rpx; }
.wave-bar:nth-child(3) { height: 60rpx; }
.wave-bar:nth-child(4) { height: 40rpx; }
.wave-bar:nth-child(5) { height: 20rpx; }

@keyframes wave {
  0%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(0.5); }
}

/* 歌曲信息 */
.player-info {
  text-align: center;
  margin: 40rpx 0;
}

.player-song-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.player-artist {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  letter-spacing: 1rpx;
}

/* 进度条 */
.player-progress {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.progress-time {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  min-width: 80rpx;
  text-align: center;
}

.progress-slider {
  flex: 1;
}

/* 控制按钮 */
.player-controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.control-btn:active {
  transform: scale(0.95);
}

.control-btn .icon {
  font-size: 40rpx;
  color: rgba(255,255,255,0.9);
}

.control-play {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
}

.control-play .icon {
  font-size: 56rpx;
  color: #fff;
}

.control-prev, .control-next {
  width: 96rpx;
  height: 96rpx;
}

.control-prev .icon, .control-next .icon {
  font-size: 48rpx;
}
