/* Markdown 渲染样式 */
.markdown-content {
  width: 100%;
}

/* 标题样式 */
.md-h1 {
  font-size: 40rpx;
  font-weight: 700;
  color: #2a3433;
  margin: 32rpx 0 16rpx 0;
  line-height: 1.4;
}

.md-h2 {
  font-size: 36rpx;
  font-weight: 700;
  color: #2a3433;
  margin: 28rpx 0 14rpx 0;
  line-height: 1.4;
}

.md-h3 {
  font-size: 32rpx;
  font-weight: 700;
  color: #2a3433;
  margin: 24rpx 0 12rpx 0;
  line-height: 1.4;
}

/* 段落样式 */
.md-paragraph {
  font-size: 30rpx;
  color: #2a3433;
  line-height: 1.8;
  margin: 16rpx 0;
}

/* 文本样式 */
.md-text {
  font-size: 30rpx;
  color: #2a3433;
  line-height: 1.8;
}

.md-bold {
  font-size: 30rpx;
  font-weight: 700;
  color: #2a3433;
}

.md-italic {
  font-size: 30rpx;
  font-style: italic;
  color: #57615f;
}

.md-inline-code {
  font-size: 26rpx;
  color: #076c59;
  background: rgba(160, 243, 218, 0.3);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-family: monospace;
}

.md-link {
  font-size: 30rpx;
  color: #076c59;
  text-decoration: underline;
}

/* 列表样式 */
.md-list {
  margin: 16rpx 0;
}

.md-list-item {
  display: flex;
  align-items: flex-start;
  margin: 12rpx 0;
}

.md-list-marker {
  font-size: 30rpx;
  color: #076c59;
  margin-right: 16rpx;
  line-height: 1.6;
}

.md-list-content {
  flex: 1;
  font-size: 30rpx;
  color: #2a3433;
  line-height: 1.6;
}

/* 引用样式 */
.md-blockquote {
  border-left: 8rpx solid #a0f3da;
  padding-left: 24rpx;
  margin: 24rpx 0;
  background: rgba(160, 243, 218, 0.1);
  padding: 20rpx 20rpx 20rpx 32rpx;
  border-radius: 0 16rpx 16rpx 0;
}

.md-blockquote .md-text {
  color: #57615f;
  font-style: italic;
}

/* 代码块样式 */
.md-code-block {
  background: #1a1a2e;
  border-radius: 16rpx;
  margin: 24rpx 0;
  overflow: hidden;
}

.md-code-lang {
  font-size: 22rpx;
  color: #a0f3da;
  background: rgba(160, 243, 218, 0.1);
  padding: 12rpx 24rpx;
  border-bottom: 1rpx solid rgba(160, 243, 218, 0.2);
}

.md-code-content {
  display: block;
  font-size: 26rpx;
  color: #e4fff4;
  padding: 24rpx;
  font-family: monospace;
  line-height: 1.6;
  white-space: pre-wrap;
  word-wrap: break-word;
}

/* 分割线样式 */
.md-hr {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, #a0f3da 50%, transparent 100%);
  margin: 32rpx 0;
}

/* 空行样式 */
.md-empty {
  height: 16rpx;
}

/* 表格样式 */
.md-table {
  width: 100%;
  border-collapse: collapse;
  margin: 24rpx 0;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  font-size: 26rpx;
}

.md-table thead {
  background: linear-gradient(135deg, rgba(160, 243, 218, 0.3) 0%, rgba(143, 180, 143, 0.2) 100%);
}

.md-th {
  padding: 20rpx 24rpx;
  text-align: left;
  font-weight: 700;
  color: #076c59;
  border-bottom: 2rpx solid rgba(160, 243, 218, 0.4);
  line-height: 1.6;
}

.md-td {
  padding: 16rpx 24rpx;
  color: #2a3433;
  border-bottom: 1rpx solid rgba(160, 243, 218, 0.15);
  line-height: 1.6;
}

.md-table tbody tr:last-child .md-td {
  border-bottom: none;
}

.md-table tbody tr:nth-child(even) {
  background: rgba(160, 243, 218, 0.08);
}
